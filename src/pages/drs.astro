    <script id="fbNews" type="application/json" set:html={JSON.stringify(fallbackNews)}></script>
    <script>
      // @ts-nocheck
      const NEWS_KEY = import.meta.env.PUBLIC_NEWSDATA_API_KEY || 'pub_8da7976a5ed14a989354155e78a73052';
      const GEMINI_KEY = import.meta.env.PUBLIC_GEMINI_API_KEY || '';
      const MODEL = import.meta.env.PUBLIC_GEMINI_MODEL || 'gemini-2.5-flash';
      const THEME_KEY = 'drs-theme-v1';
      const PANEL_KEY = 'drs-panel-v1';
      const NEWS_LOADING_MIN_MS = 1000;
      const NEWS_LOADING_MAX_MS = 2000;
      const KPI_REVENUE_CAP = 6.0;
      const $ = s => document.querySelector(s);
      const $$ = s => Array.from(document.querySelectorAll(s));
      const esc = v => String(v ?? '').replace(/[&<>"']/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[m]));
      const NEWS_PLACEHOLDER = '/news/news-placeholder.svg';
      const fallbackNews = dedupeStories(JSON.parse($('#fbNews')?.textContent || '[]'));
      const state = {
        news: [...fallbackNews],
        live: false,
        score: 64,
        rev: 2.4,
        svc: 95.1,
        actions: [],
        newsPage: '',
        newsError: '',
        lastNewsFetch: '',
        fetchInFlight: false,
        newsLoading: false
      };

      const refs = {
        newsDot: $('#newsDot'), gemDot: $('#gemDot'), newsMode: $('#newsMode'), gemMode: $('#gemMode'), cycle: $('#cycle'),
        kRisk: $('#kRisk'), kRev: $('#kRev'), kSvc: $('#kSvc'), kAct: $('#kAct'), riskBand: $('#riskBand'),
        riskPie: $('#riskPie'), revFill: $('#revFill'), revMarker: $('#revMarker'), revCap: $('#revCap'),
        svcFill: $('#svcFill'), svcProtected: $('#svcProtected'), svcAtRisk: $('#svcAtRisk'),
        mitLabel: $('#mitLabel'), mitNodes: $$('#mitGraph .mit-node'),
        dashNews: $('#dashNews'), newsCards: $('#newsCards'), signalList: $('#signalList'), actionList: $('#actionList'),
        recommendation: $('#recommendation'), statusText: $('#statusText'), governance: $('#governance'),
        emailDraft: $('#emailDraft'), erpDraft: $('#erpDraft'), execDraft: $('#execDraft'),
        emailFlag: $('#emailFlag'), erpFlag: $('#erpFlag'), execFlag: $('#execFlag'),
        chat: $('#chat'), chatForm: $('#chatForm'), chatInput: $('#chatInput'), chatSend: $('#chatSend'), copilotStatus: $('#copilotStatus'), copilotNote: $('#copilotNote')
      };

      const baseSignals = [
        ['PO-4102 lead-time variance +5 days on microcontrollers', 'Procurement', 'high'],
        ['EU-Central lane utilization exceeded 92% threshold', 'Logistics', 'medium'],
        ['Inventory cover projected below 9 days for SLA-critical SKU-88', 'Inventory', 'high'],
        ['Overtime freight spend trend +11% versus baseline', 'Cost', 'medium']
      ];

      function formatDate(iso){ const d = new Date(iso); return Number.isNaN(d.getTime()) ? 'Unknown date' : d.toLocaleString([], { month:'short', day:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }); }
      function clamp(n,min,max){ return Math.max(min,Math.min(max,n)); }
      function wait(ms){ return new Promise(resolve => setTimeout(resolve, ms)); }
      function randomNewsDelay(){ return NEWS_LOADING_MIN_MS + Math.floor(Math.random() * (NEWS_LOADING_MAX_MS - NEWS_LOADING_MIN_MS + 1)); }
      const animatedKpi = { risk: 0, rev: 0, svc: 0 };
      const animatedFrame = {};
      function animateKpi(key, target, updater, duration = 700){
        const start = Number.isFinite(animatedKpi[key]) ? animatedKpi[key] : target;
        if(animatedFrame[key]) cancelAnimationFrame(animatedFrame[key]);
        if(Math.abs(target - start) < 0.15){
          animatedKpi[key] = target;
          updater(target);
          return;
        }
        const startAt = performance.now();
        const step = now => {
          const t = Math.min((now - startAt) / duration, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          const value = start + (target - start) * eased;
          animatedKpi[key] = value;
          updater(value);
          if(t < 1){
            animatedFrame[key] = requestAnimationFrame(step);
          }
        };
        animatedFrame[key] = requestAnimationFrame(step);
      }
      function profile(){ return { con:Number($('#pCon').value), reg:Number($('#pReg').value), lead:Number($('#pLead').value), buf:Number($('#pBuf').value), sla:Number($('#pSla').value), th:Number($('#threshold').value), mode:$('#autonomy').value }; }
      function classify(t){ const s=String(t||'').toLowerCase(); return /(insolvency|strike|shutdown|outage|war)/.test(s)?'high':/(delay|congestion|tariff|weather|pressure)/.test(s)?'medium':'low'; }
      function escapeAttr(v){ return esc(v).replace(/`/g,''); }
      function normalizeHeadline(v){
        return String(v || '')
          .toLowerCase()
          .replace(/https?:\/\/\S+/g, ' ')
          .replace(/[^a-z0-9\s]/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
      }
      function canonicalUrl(v){
        const raw = String(v || '').trim();
        if(!raw) return '';
        try {
          const u = new URL(raw);
          u.search = '';
          u.hash = '';
          return `${u.origin}${u.pathname}`.replace(/\/+$/, '').toLowerCase();
        } catch {
          return raw.toLowerCase();
        }
      }
      function storyKey(item){
        const title = normalizeHeadline(item.title);
        if(title) return `title:${title}`;
        const articleId = String(item.articleId || item.id || '').trim().toLowerCase();
        if(articleId) return `id:${articleId}`;
        const url = canonicalUrl(item.url);
        return url ? `url:${url}` : '';
      }
      function shouldReplaceStory(nextItem, currentItem){
        const nextHasImage = Boolean(nextItem.image && nextItem.image !== NEWS_PLACEHOLDER);
        const currentHasImage = Boolean(currentItem.image && currentItem.image !== NEWS_PLACEHOLDER);
        if(nextHasImage !== currentHasImage) return nextHasImage;
        const nextTime = Date.parse(nextItem.date || '');
        const currentTime = Date.parse(currentItem.date || '');
        return Number.isFinite(nextTime) && (!Number.isFinite(currentTime) || nextTime > currentTime);
      }
      function dedupeStories(items){
        const unique = new Map();
        for(const rawItem of Array.isArray(items) ? items : []){
          const item = {
            ...rawItem,
            title: String(rawItem?.title || 'Signal update').trim(),
            publisher: String(rawItem?.publisher || rawItem?.source_name || rawItem?.source_id || 'Unknown publisher').trim(),
            author: Array.isArray(rawItem?.author)
              ? (rawItem.author.filter(Boolean).join(', ') || 'Unknown author')
              : String(rawItem?.author || rawItem?.creator || 'Unknown author').trim(),
            date: rawItem?.date || rawItem?.pubDate || rawItem?.published_at || new Date().toISOString(),
            image: String(rawItem?.image || rawItem?.image_url || '').trim(),
            url: String(rawItem?.url || rawItem?.link || '').trim(),
            articleId: String(rawItem?.articleId || rawItem?.article_id || rawItem?.id || '').trim()
          };
          if(!item.title || !item.url) continue;
          const key = storyKey(item);
          if(!key) continue;
          const current = unique.get(key);
          if(!current || shouldReplaceStory(item, current)){
            unique.set(key, item);
          }
        }
        return Array.from(unique.values()).map(item => ({
          ...item,
          image: item.image || NEWS_PLACEHOLDER
        }));
      }
      function buildDashNewsSkeleton(count){
        return Array.from({ length: count }, () => `
          <article class="mini-card skeleton-card">
            <div class="skel skel-thumb"></div>
            <div class="skel-stack">
              <div class="skel skel-line lg"></div>
              <div class="skel skel-line md"></div>
              <div class="skel skel-line sm"></div>
            </div>
          </article>
        `).join('');
      }
      function buildNewsGridSkeleton(count){
        return Array.from({ length: count }, () => `
          <article class="news-card skeleton-card">
            <div class="skel skel-thumb"></div>
            <div class="skel skel-line lg"></div>
            <div class="skel skel-line md"></div>
            <div class="skel skel-line sm"></div>
          </article>
        `).join('');
      }
      function setTheme(theme){ const value = theme === 'dark' ? 'dark' : 'light'; document.documentElement.dataset.theme = value; localStorage.setItem(THEME_KEY, value); $$('[data-theme]').forEach(b=>b.classList.toggle('active', b.getAttribute('data-theme')===value)); }
      function initTheme(){ const saved = localStorage.getItem(THEME_KEY); const preferred = saved || 'dark'; setTheme(preferred); }

      function showPanel(id){
        const target = $('#' + id) || $('#dashboard');
        $$('.panel').forEach(p=>{ const on = p.id === target.id; p.classList.toggle('active', on); p.setAttribute('aria-hidden', on ? 'false':'true'); });
        $$('[data-panel]').forEach(btn=>btn.classList.toggle('active', btn.getAttribute('data-panel')===target.id));
        localStorage.setItem(PANEL_KEY, target.id);
      }

      function compute(){
        const p = profile();
        const high = state.news.filter(n => classify(n.title)==='high').length;
        const med = state.news.filter(n => classify(n.title)==='medium').length;
        const raw = 34 + high*7 + med*3 + p.con*.12 + p.reg*.1 + p.lead*.11 + p.sla*.08 - p.buf*1.12;
        state.score = clamp(Math.round(raw),18,96);
        state.rev = Number((0.9 + state.score*0.034).toFixed(1));
        state.svc = Number(clamp(99.2 - state.score*0.13 + p.buf*0.1,78.4,99.8).toFixed(1));
        const breach = state.score >= p.th;
        state.actions = [
          { title:'Supplier outreach draft', owner:'Procurement Lead', status:p.mode==='assist'?'Awaiting approval':'Queued' },
          { title:'ERP reorder point adjustment', owner:'Planning Ops', status:p.mode==='assist'?'Awaiting approval':'Queued' },
          { title:'Execute lane reroute plus expedite', owner:'DRS Orchestrator', status:p.mode==='auto'?'Auto-running':'Pending review' },
          ...(breach ? [{ title:'Executive escalation package', owner:'COO Office', status:p.mode==='assist'?'Awaiting approval':'Triggered' }] : [])
        ];
        refs.emailDraft.textContent = `Subject: Capacity reconfirmation. Elevated risk ${state.score}/100 tied to "${state.news[0]?.title || 'latest signal'}". Confirm 14-day capacity and expedite options.`;
        refs.erpDraft.textContent = `Raise reorder points by 9-14% and lift buffer from ${Math.max(7,p.buf)} to ${Math.max(10,p.buf+4)} days for top SLA SKUs.`;
        refs.execDraft.textContent = breach ? `Escalation required: score ${state.score} exceeded threshold ${p.th}. Revenue-at-risk $${state.rev.toFixed(1)}M.` : `No escalation. Score ${state.score} is below threshold ${p.th}.`;
        refs.emailFlag.textContent = 'Generated'; refs.erpFlag.textContent = 'Generated'; refs.execFlag.textContent = breach ? 'Triggered' : 'Standby';
      }

      function renderKpis(riskColor){
        refs.riskPie.style.setProperty('--tone', riskColor);
        animateKpi('risk', state.score, value => refs.riskPie.style.setProperty('--value', value.toFixed(2)), 780);

        const revPercent = clamp((state.rev / KPI_REVENUE_CAP) * 100, 0, 100);
        animateKpi('rev', revPercent, value => {
          const pct = `${value.toFixed(2)}%`;
          refs.revFill.style.width = pct;
          refs.revMarker.style.left = pct;
        }, 680);
        refs.revCap.textContent = `$${KPI_REVENUE_CAP.toFixed(1)}M window cap`;

        animateKpi('svc', state.svc, value => {
          refs.svcFill.style.width = `${value.toFixed(2)}%`;
        }, 680);
        const riskGap = clamp(100 - state.svc, 0, 100);
        refs.svcProtected.textContent = `${state.svc.toFixed(1)}% protected`;
        refs.svcAtRisk.textContent = `${riskGap.toFixed(1)}% at risk`;

        const totalNodes = refs.mitNodes.length || 6;
        const activeNodes = clamp(state.actions.length, 0, totalNodes);
        refs.mitNodes.forEach((node, index) => {
          node.classList.toggle('active', index < activeNodes);
          node.style.animationDelay = `${index * 100}ms`;
        });
        refs.mitLabel.textContent = `${activeNodes}/${totalNodes} lanes engaged`;
      }

      function render(){
        refs.kRisk.textContent = `${state.score} / 100`;
        refs.kRev.textContent = `$${state.rev.toFixed(1)}M`;
        refs.kSvc.textContent = `${state.svc.toFixed(1)}%`;
        refs.kAct.textContent = String(state.actions.length);
        refs.riskBand.textContent = state.score>=80 ? 'Risk band: High' : state.score>=62 ? 'Risk band: Medium' : 'Risk band: Controlled';
        const riskColor = state.score>=80 ? '#c63636' : state.score>=62 ? '#d97706' : '#16a34a';
        refs.riskBand.style.color = riskColor;
        renderKpis(riskColor);

        if(state.newsLoading){
          refs.dashNews.innerHTML = buildDashNewsSkeleton(4);
          refs.newsCards.innerHTML = buildNewsGridSkeleton(9);
        } else {
          refs.dashNews.innerHTML = state.news.slice(0,4).map(n=>`<a class="mini-card" href="${escapeAttr(n.url)}" target="_blank" rel="noreferrer noopener"><img class="thumb" src="${escapeAttr(n.image || NEWS_PLACEHOLDER)}" alt="News thumbnail" loading="lazy" onerror="this.onerror=null;this.src='${NEWS_PLACEHOLDER}';" /><div><p class="news-title">${esc(n.title)}</p><p class="meta">${esc(n.publisher)} | ${esc(n.author)} | ${esc(formatDate(n.date))}</p></div></a>`).join('');
          refs.newsCards.innerHTML = state.news.slice(0,10).map(n=>`<a class="news-card" href="${escapeAttr(n.url)}" target="_blank" rel="noreferrer noopener"><img class="thumb" src="${escapeAttr(n.image || NEWS_PLACEHOLDER)}" alt="Live news thumbnail" loading="lazy" referrerpolicy="no-referrer" onerror="this.onerror=null;this.src='${NEWS_PLACEHOLDER}';" /><h3 style="margin:0;font-size:.75rem;line-height:1.25;">${esc(n.title)}</h3><p class="meta">Publisher: ${esc(n.publisher)}</p><p class="meta">Author: ${esc(n.author)}</p><p class="meta">Date: ${esc(formatDate(n.date))}</p></a>`).join('');
        }

        refs.signalList.innerHTML = baseSignals.map(s=>`<article class="item"><div class="item-head"><span>${esc(s[1])}</span><span class="pill ${esc(s[2])}">${esc(String(s[2]).toUpperCase())}</span></div><p>${esc(s[0])}</p></article>`).join('');
        refs.actionList.innerHTML = state.actions.map(a=>`<article class="item"><div class="item-head"><span>${esc(a.owner)}</span><span class="pill ${String(a.status).toLowerCase().includes('approval')?'medium':'low'}">${esc(a.status)}</span></div><p>${esc(a.title)}</p></article>`).join('');

        refs.recommendation.textContent = `Recommendation: ${state.actions[2]?.title || '--'}`;
        refs.statusText.textContent = state.newsLoading
          ? `Refreshing stories... | Delay ${NEWS_LOADING_MIN_MS / 1000}-${NEWS_LOADING_MAX_MS / 1000}s`
          : `${state.live ? 'Live news active' : 'Fallback news active'} | Stories ${state.news.length} | Last sync ${state.lastNewsFetch || 'not synced'}${state.newsError ? ` | API: ${state.newsError}` : ''}`;
        refs.newsMode.textContent = state.newsLoading
          ? 'News: Refreshing...'
          : state.live ? `News: Live (${state.news.length})` : `News: Fallback (${state.news.length})`;
        refs.newsDot.className = state.newsLoading ? 'dot warn' : `dot ${state.live ? 'live' : 'warn'}`;
        refs.gemMode.textContent = GEMINI_KEY ? `Gemini: ${MODEL}` : 'Gemini: Fallback';
        refs.gemDot.className = `dot ${GEMINI_KEY ? 'live' : 'warn'}`;
        refs.cycle.textContent = `Cycle: ${new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}`;
        refs.governance.textContent = `${NEWS_KEY ? 'PUBLIC_NEWSDATA_API_KEY detected.' : 'Missing PUBLIC_NEWSDATA_API_KEY (demo mode).'} ${GEMINI_KEY ? 'PUBLIC_GEMINI_API_KEY detected.' : 'Missing PUBLIC_GEMINI_API_KEY (fallback copilot).'} Guardrail threshold: ${$('#threshold').value}. News API status: ${state.live ? 'live feed' : 'fallback mode'}${state.newsError ? ` (${state.newsError})` : ''}.`;
      }

      async function fetchNews(){
        if(!NEWS_KEY){
          state.news = [...fallbackNews];
          state.live = false;
          state.newsError = 'missing API key';
          state.lastNewsFetch = new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', second:'2-digit'});
          return;
        }
        try {
          const params = new URLSearchParams({
            apikey: NEWS_KEY,
            language: 'en',
            category: 'business',
            size: '10',
            image: '1',
            q: '(supply chain OR logistics OR semiconductor OR tariffs OR manufacturing disruption)'
          });
          if(state.newsPage) params.set('page', state.newsPage);

          const url = `https://newsdata.io/api/1/news?${params.toString()}`;
          const r = await fetch(url, { cache: 'no-store' });
          const d = await r.json().catch(() => ({}));
          if(!r.ok || d?.status !== 'success'){
            const message = d?.results?.message || d?.message || `http ${r.status}`;
            throw new Error(message);
          }

          const rows = (Array.isArray(d.results) ? d.results : [])
            .map((x,i)=>({
              id: x.article_id || x.link || `${x.title || 'news'}-${i}`,
              articleId: x.article_id || '',
              title: x.title || 'Signal update',
              publisher: x.source_name || x.source_id || 'Unknown publisher',
              author: Array.isArray(x.creator) ? (x.creator.filter(Boolean).join(', ') || 'Unknown author') : (x.creator || x.author || 'Unknown author'),
              date: x.pubDate || x.published_at || new Date().toISOString(),
              image: x.image_url || '',
              url: x.link || x.url || ''
            }))
            .filter(n=>n.title && n.url);

          const deduped = dedupeStories(rows).slice(0, 10);
          if(!deduped.length) throw new Error('empty result set');

          state.news = deduped;
          state.live = true;
          state.newsPage = typeof d?.nextPage === 'string' ? d.nextPage : '';
          state.newsError = '';
          state.lastNewsFetch = new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', second:'2-digit'});
        } catch (error) {
          if(!state.news.length){
            state.news = [...fallbackNews];
          }
          state.live = false;
          state.newsError = error instanceof Error ? error.message : 'fetch failed';
          state.lastNewsFetch = new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', second:'2-digit'});
        }
      }

      async function ask(prompt){
        const text = String(prompt || '').trim();
        if(!text) return;
        const user = document.createElement('div'); user.className='bubble user'; user.textContent=text; refs.chat.appendChild(user);
        refs.chatSend.disabled=true; refs.chatSend.textContent='Thinking...'; refs.copilotStatus.textContent='Reasoning';
        let errMsg = '';
        try {
          let reply = `Risk ${state.score}/100 with exposure $${state.rev.toFixed(1)}M. Mitigation: ${state.actions[2]?.title || 'Supplier reallocation'}.`;
          if(!GEMINI_KEY){
            errMsg = 'PUBLIC_GEMINI_API_KEY not set. Add it to .env and restart the dev server.';
          } else {
            const ctx = `Current state: Risk ${state.score}/100, revenue-at-risk $${state.rev.toFixed(1)}M, service protection ${state.svc.toFixed(1)}%. Active mitigation: ${state.actions[2]?.title || 'Supplier reallocation'}.`;
            const sys = `You are Resolv DRS, a supply chain resilience co-pilot. ${ctx}

If the user greets you or says something casual (hi, hey, what, etc.), reply briefly and offer to help with mitigation questions.
If they ask about mitigation, risk, or recommendations, give a clear 2–4 sentence answer using the current state above. Be specific and actionable.`;
            const body = { contents:[{parts:[{text:`${sys}\n\nUser: ${text}\n\nYour response:`}]}], generationConfig:{temperature:0.3,maxOutputTokens:512} };
            const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:generateContent?key=${GEMINI_KEY}`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
            const data = await res.json().catch(()=>({}));
            if(res.ok){
              const out = (data?.candidates?.[0]?.content?.parts || []).map(p=>p.text||'').join(' ').trim();
              if(out) reply = out;
            } else {
              errMsg = data?.error?.message || `HTTP ${res.status}`;
            }
          }
          const bot = document.createElement('div'); bot.className='bubble'; bot.textContent = errMsg ? `LLM error: ${errMsg}` : reply; refs.chat.appendChild(bot);
          refs.copilotNote.innerHTML = `<p>${esc(errMsg ? `Error: ${errMsg}` : reply)}</p>`;
        } catch (e) {
          errMsg = e instanceof Error ? e.message : String(e);
          const bot = document.createElement('div'); bot.className='bubble'; bot.textContent=`LLM error: ${errMsg}`; refs.chat.appendChild(bot);
          refs.copilotNote.innerHTML = `<p>${esc(`Error: ${errMsg}`)}</p>`;
        } finally {
          while(refs.chat.children.length > 7) refs.chat.removeChild(refs.chat.firstElementChild);
          refs.chatSend.disabled=false; refs.chatSend.textContent='Send'; refs.copilotStatus.textContent='Ready';
        }
      }

      async function refreshAll(){
        if(state.fetchInFlight) return;
        state.fetchInFlight = true;
        try {
          state.newsLoading = true;
          render();
          await Promise.all([fetchNews(), wait(randomNewsDelay())]);
          state.newsLoading = false;
          compute();
          render();
        } finally {
          state.newsLoading = false;
          state.fetchInFlight = false;
        }
      }

      function bind(){
        $$('[data-panel]').forEach(btn=>btn.addEventListener('click',()=>showPanel(btn.getAttribute('data-panel')||'dashboard')));
        $$('[data-jump]').forEach(btn=>btn.addEventListener('click',()=>showPanel(btn.getAttribute('data-jump')||'dashboard')));
        $('#refreshNews').addEventListener('click',()=>refreshAll());
        $('#runCycle').addEventListener('click',()=>{ compute(); render(); refs.copilotStatus.textContent='Workflow cycle complete'; setTimeout(()=>refs.copilotStatus.textContent='Ready',1000); });
        refs.chatForm.addEventListener('submit',e=>{ e.preventDefault(); const v=refs.chatInput.value; refs.chatInput.value=''; ask(v); });
        $$('[data-prompt]').forEach(btn=>btn.addEventListener('click',()=>ask(btn.getAttribute('data-prompt')||'')));
        [['#pCon','#pConV',false],['#pReg','#pRegV',false],['#pLead','#pLeadV',false],['#pBuf','#pBufV',true],['#pSla','#pSlaV',false],['#threshold','#thresholdV',false]].forEach(([i,v,d])=>$(i).addEventListener('input',()=>{ $(v).textContent=d?`${$(i).value} days`:$(i).value; compute(); render(); }));
        $('#autonomy').addEventListener('change',()=>{ compute(); render(); });
        $('#openSettings').addEventListener('click',()=>$('#settingsOverlay').hidden=false);
        $('#closeSettings').addEventListener('click',()=>$('#settingsOverlay').hidden=true);
        $('#settingsOverlay').addEventListener('click',e=>{ if(e.target === $('#settingsOverlay')) $('#settingsOverlay').hidden=true; });
        document.addEventListener('keydown',e=>{ if(e.key==='Escape') $('#settingsOverlay').hidden=true; });
        $$('[data-theme]').forEach(btn=>btn.addEventListener('click',()=>setTheme(btn.getAttribute('data-theme')||'light')));
      }

      async function init(){
        initTheme();
        bind();
        showPanel(localStorage.getItem(PANEL_KEY) || 'dashboard');
        await refreshAll();
        setInterval(refreshAll, 15000);
      }
      init();
    </script>
  </body>
</html>
