---
import Meta from '@components/Meta.astro';
import '@styles/global.css';

const pageTitle = 'Resolv DRS Studio';
const fallbackNews = [
  {
    title: 'Port congestion rises across Atlantic lanes after labor action',
    publisher: 'Global Logistics Monitor',
    author: 'Lena Ortiz',
    date: '2026-03-03T14:10:00Z',
    image: '/news/news-placeholder.svg',
    url: 'https://www.reuters.com/world/'
  },
  {
    title: 'Tariff review announced for electrical modules in EU',
    publisher: 'Market Policy Desk',
    author: 'Rohan Patel',
    date: '2026-03-03T13:45:00Z',
    image: '/news/news-placeholder.svg',
    url: 'https://www.reuters.com/world/europe/'
  },
  {
    title: 'Supplier insolvency warning issued for tier-2 capacitor vendor',
    publisher: 'Supplier Finance Wire',
    author: 'Maya Chen',
    date: '2026-03-03T13:01:00Z',
    image: '/news/news-placeholder.svg',
    url: 'https://www.reuters.com/markets/'
  },
  {
    title: 'Weather event disrupts rail transfer hub for inland plants',
    publisher: 'Freight Intelligence',
    author: 'Jonas Bell',
    date: '2026-03-03T12:30:00Z',
    image: '/news/news-placeholder.svg',
    url: 'https://www.reuters.com/business/'
  },
  {
    title: 'Semiconductor lead-time pressure returns in power modules',
    publisher: 'Manufacturing Wire',
    author: 'Iris Khan',
    date: '2026-03-03T12:02:00Z',
    image: '/news/news-placeholder.svg',
    url: 'https://www.reuters.com/technology/'
  },
  {
    title: 'Marine insurance surcharges increase after security advisory',
    publisher: 'Trade Security Daily',
    author: 'David Moss',
    date: '2026-03-03T11:19:00Z',
    image: '/news/news-placeholder.svg',
    url: 'https://www.reuters.com/world/middle-east/'
  },
  {
    title: 'Border processing delays impact bonded freight releases',
    publisher: 'Customs Operations Report',
    author: 'Nina Brooks',
    date: '2026-03-03T10:41:00Z',
    image: '/news/news-placeholder.svg',
    url: 'https://www.reuters.com/world/'
  },
  {
    title: 'Industrial labor agreement uncertainty raises output risk',
    publisher: 'Plant Operations Desk',
    author: 'Owen Hart',
    date: '2026-03-03T10:12:00Z',
    image: '/news/news-placeholder.svg',
    url: 'https://www.reuters.com/business/'
  }
];

const companyDossier = `HDT Industrial - Enterprise DRS Company Profile

Legal Name: HDT Industrial Manufacturing Group, Inc.
Operating Name: HDT Industrial
Headquarters: Cleveland, Ohio, United States
Founded: 1987
Primary Industry: Heavy-duty industrial components, control systems, and powertrain subassemblies
Ownership: Private equity majority stake with management rollover
Employee Count: 7,480 global employees
Manufacturing Sites: 13 plants across US, Mexico, Poland, and Vietnam
Distribution Hubs: 9 regional hubs with cross-dock operations
Annual Revenue: USD 3.84B (latest closed fiscal year)
EBITDA Margin: 14.8%
Top Product Families: Industrial drives, motion controllers, ruggedized power modules, torque assemblies, safety relay systems

Business Segments:
1) Energy and Utilities Components (31%)
2) Industrial Automation and Robotics Assemblies (28%)
3) Transportation and Fleet Systems (24%)
4) Aftermarket Service Parts and Kits (17%)

Top Customers by Revenue Exposure:
- Northline Energy Systems (11.4%)
- Arcadia Motion Platforms (9.7%)
- Granite Freight Technologies (8.6%)
- Meridian Water Utilities (7.2%)
- Atlas Fleet Services (6.8%)

SLA Commitments:
- 98.7% OTIF for Tier-A customers
- 96-hour emergency replenishment for critical assemblies
- 24-hour quote response for disruption-based reroute requests

Supplier Network Summary:
- Total Active Suppliers: 462
- Strategic Tier-1 Suppliers: 74
- Single-source critical components: 19
- Region concentration: North America 48%, Europe 31%, APAC 21%
- Average contract duration: 2.8 years
- Contracts with force-majeure escalation clauses: 63%

High-Risk Inputs:
- SiC power semiconductors
- Precision bearings above 40mm class
- Copper-intensive busbar assemblies
- Specialized thermal interface compounds
- Industrial Ethernet microcontrollers

Inbound Logistics Profile:
- Ocean freight share: 37%
- Air freight share: 9%
- Rail/intermodal share: 22%
- Truckload + LTL share: 32%
- Highest-risk lanes: Gdansk to Houston, Veracruz to Laredo, Hai Phong to Long Beach

Inventory Strategy:
- Critical component target cover: 14 days
- Non-critical target cover: 8 days
- Current weighted days-of-cover: 9.6
- Safety stock policy review cycle: monthly
- Obsolescence reserve threshold: 1.8% of stock value

Finance and Risk Indicators:
- Working capital tied to inventory: USD 612M
- Expedited freight budget: USD 42M annual
- Current budget burn rate: +13.2% versus plan
- Revenue-at-risk threshold for exec escalation: USD 3.2M per 72-hour window
- Cash conversion cycle: 74 days

Operational Constraints:
- Two US plants near full utilization above 92%
- PLC firmware certification process adds 10-14 day delay for alternate line qualification
- Union schedule restrictions in Plant OH-02 reduce overtime flexibility during weeknights
- Test bench capacity bottleneck in high-torque product line

DRS Governance Configuration:
- Autonomy Mode: Semi-autonomous by policy
- Human Override Threshold: 78 risk score
- Auto-approve categories: inventory rebalance under USD 120K impact
- Manual approval categories: supplier contract amendments, lane changes above USD 250K spend
- Compliance overlays: ISO 9001, ISO 14001, customer-specific PPAP requirements

Active Strategic Initiatives:
- Dual-source program for top 12 constrained SKUs
- Nearshoring pilot for controller board assembly in Texas
- Predictive maintenance rollout for CNC cell downtime reduction
- Carbon-adjusted freight routing trial for EU customer base
- Vendor scorecard automation linked to late shipment penalties

Executive Priorities for Current Quarter:
- Reduce disruption response time by 35%
- Increase multi-sourced critical SKUs from 41% to 57%
- Lower emergency freight usage by 18%
- Protect Tier-A service level above 98% during demand spikes
- Improve early warning confidence score in DRS from 0.71 to 0.82`;
---

<html lang="en">
  <head>
    <Meta customDescription="Resolv DRS autonomous resilience command studio" customOgTitle={pageTitle} />
    <title>{pageTitle}</title>
    <style is:inline>
      :root {
        --font: 'Segoe UI', sans-serif;
        --bg: #e5e5e5;
        --surface: rgba(245, 245, 245, 0.92);
        --line: rgba(39, 39, 42, 0.15);
        --text: #18181b;
        --muted: #52525b;
        --accent: #52525b;
        --success: #166534;
        --warn: #a16207;
        --skel-a: rgba(63, 63, 70, 0.22);
        --skel-b: rgba(161, 161, 170, 0.42);
      }
      :root[data-theme='dark'] {
        --bg: #262626;
        --surface: rgba(38, 38, 38, 0.92);
        --line: rgba(245, 245, 245, 0.16);
        --text: #f5f5f5;
        --muted: #a1a1aa;
        --accent: #737373;
        --success: #4ade80;
        --warn: #fbbf24;
        --skel-a: rgba(63, 63, 70, 0.45);
        --skel-b: rgba(161, 161, 170, 0.58);
      }
      * {
        box-sizing: border-box;
        font-family: var(--font);
        font-weight: 400;
      }
      h1, h2, h3, strong, button, .chip, .pill, .nav-btn.active { font-weight: 500; }
      html, body { margin: 0; height: 100%; overflow: hidden; color: var(--text); background: var(--bg); }
      .app { height: 100%; display: grid; grid-template-rows: auto auto 1fr; gap: 10px; padding: 12px; }
      .card { border: 1px solid var(--line); border-radius: 14px; background: var(--surface); backdrop-filter: blur(10px); }
      .top { display: grid; grid-template-columns: 1fr auto auto; gap: 10px; align-items: center; padding: 10px 12px; }
      .brand h1 { margin: 0; font-size: 1rem; color: var(--text); }
      .brand p { margin: 4px 0 0; font-size: .75rem; color: var(--muted); }
      .chips { display: flex; gap: 7px; flex-wrap: wrap; justify-content: flex-end; }
      .chip { display: inline-flex; gap: 6px; align-items: center; border: 1px solid var(--line); border-radius: 999px; padding: 5px 9px; font-size: .7rem; }
      .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--muted); }
      .dot.live { background: var(--success); }
      .dot.warn { background: var(--warn); }
      .icon { width: 36px; height: 36px; border: 1px solid var(--line); border-radius: 10px; background: transparent; color: var(--text); cursor: pointer; }
      .tabs { display: flex; gap: 7px; padding: 7px; overflow: hidden; }
      .nav-btn { border: 1px solid transparent; border-radius: 9px; padding: 7px 10px; font-size: .74rem; color: var(--muted); background: transparent; cursor: pointer; }
      .nav-btn.active { border-color: var(--line); color: var(--text); }
      .workspace { min-height: 0; padding: 9px; overflow: hidden; }
      .panel { display: none; height: 100%; min-height: 0; gap: 9px; }
      .panel.active { display: grid; }
      .dashboard { grid-template-rows: auto 1fr; }
      .kpis { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 8px; }
      .kpi {
        border: 1px solid var(--line);
        border-radius: 11px;
        padding: 9px;
        display: grid;
        gap: 8px;
        min-height: 132px;
        background: linear-gradient(145deg, rgba(255,255,255,.08), rgba(255,255,255,0) 72%);
      }
      :root[data-theme='dark'] .kpi {
        background: linear-gradient(145deg, rgba(255,255,255,.03), rgba(0,0,0,.12) 72%);
      }
      .kpi h2 { margin: 0; font-size: .72rem; color: var(--muted); }
      .kpi-head { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
      .kpi-body { display: grid; gap: 8px; }
      .risk-body { grid-template-columns: auto 1fr; align-items: center; gap: 10px; }
      .risk-pie {
        --value: 0;
        --tone: var(--warn);
        width: 84px;
        height: 84px;
        border-radius: 50%;
        border: 1px solid var(--line);
        display: grid;
        place-items: center;
        position: relative;
        background: conic-gradient(var(--tone) calc(var(--value) * 1%), rgba(115, 115, 115, .2) 0);
      }
      .risk-pie::after {
        content: '';
        position: absolute;
        inset: 12px;
        border-radius: 50%;
        background: var(--surface);
        border: 1px solid var(--line);
      }
      .metric {
        display: block;
        margin-top: 0;
        font-size: 1.2rem;
        line-height: 1.1;
      }
      .metric-in-chart {
        position: relative;
        z-index: 1;
        font-size: .86rem;
        line-height: 1.15;
        text-align: center;
      }
      .kpi-copy { display: grid; gap: 5px; }
      .small { font-size: .69rem; color: var(--muted); }
      .small.subtle { font-size: .64rem; line-height: 1.25; opacity: .9; }
      .rev-meter {
        position: relative;
        height: 16px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(115, 115, 115, .16);
        overflow: hidden;
      }
      .rev-fill {
        position: absolute;
        inset: 0 auto 0 0;
        width: 0%;
        background: linear-gradient(90deg, #16a34a 0%, #f59e0b 56%, #dc2626 100%);
      }
      .rev-marker {
        position: absolute;
        left: 0%;
        top: -3px;
        width: 2px;
        height: 22px;
        border-radius: 999px;
        background: rgba(245, 245, 245, .88);
        box-shadow: 0 0 8px rgba(245, 245, 245, .35);
        transform: translateX(-50%);
      }
      .kpi-scale { display: flex; justify-content: space-between; gap: 8px; font-size: .62rem; color: var(--muted); }
      .kpi-row { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
      .svc-pill {
        border: 1px solid rgba(22, 163, 74, .4);
        background: rgba(22, 163, 74, .18);
        color: var(--success);
        border-radius: 999px;
        padding: 2px 7px;
        font-size: .62rem;
      }
      .svc-meter {
        height: 14px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(115, 115, 115, .15);
        overflow: hidden;
      }
      .svc-fill {
        height: 100%;
        width: 0%;
        border-radius: inherit;
        background: linear-gradient(90deg, #0f766e 0%, #22c55e 100%);
      }
      .mit-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0,1fr));
        gap: 7px;
      }
      .mit-node {
        height: 14px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(115, 115, 115, .14);
      }
      .mit-node.active {
        border-color: rgba(22, 163, 74, .45);
        background: linear-gradient(90deg, rgba(6, 182, 212, .35), rgba(22, 163, 74, .42));
        animation: mitPulse 1.9s ease-in-out infinite;
      }
      @keyframes mitPulse {
        0%, 100% { opacity: .7; }
        50% { opacity: 1; transform: translateY(-1px); }
      }
      .grid2 { min-height: 0; display: grid; grid-template-columns: 1.2fr 1fr; gap: 8px; }
      .box { border: 1px solid var(--line); border-radius: 11px; padding: 9px; min-height: 0; display: grid; gap: 8px; }
      .head { display: flex; justify-content: space-between; align-items: center; gap: 7px; border-bottom: 1px solid var(--line); padding-bottom: 7px; }
      .head h3 { margin: 0; font-size: .82rem; }
      .head p { margin: 3px 0 0; font-size: .7rem; color: var(--muted); }
      .btn, .ghost, .tiny, .control, .select { border: 1px solid var(--line); border-radius: 9px; font: inherit; }
      .btn, .ghost { height: 32px; padding: 0 10px; font-size: .73rem; cursor: pointer; }
      .btn { background: var(--accent); color: #fff; }
      .ghost { background: transparent; color: var(--text); }
      .news-mini { display: grid; gap: 7px; }
      .mini-card { display: grid; grid-template-columns: 104px 1fr; gap: 7px; border: 1px solid var(--line); border-radius: 11px; padding: 6px; text-decoration: none; color: inherit; background: color-mix(in srgb, var(--bg) 92%, #fff 8%); }
      .thumb {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        height: auto;
        object-fit: cover;
        object-position: center;
        border-radius: 10px;
        border: 1px solid var(--line);
        box-shadow:
          0 14px 28px -22px rgba(0, 0, 0, .5),
          0 3px 8px -6px rgba(0, 0, 0, .4);
        filter: saturate(1.03) contrast(1.04);
        transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
      }
      .news-title { margin: 0; font-size: .74rem; line-height: 1.24; }
      .meta { margin: 4px 0 0; font-size: .66rem; color: var(--muted); line-height: 1.24; }
      .news-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 8px; align-content: start; }
      .news-card { border: 1px solid var(--line); border-radius: 12px; padding: 7px; text-decoration: none; color: inherit; display: grid; gap: 6px; background: color-mix(in srgb, var(--bg) 92%, #fff 8%); }
      .news-card .thumb { width: 100%; aspect-ratio: 16 / 9; height: auto; }
      .mini-card:hover .thumb,
      .news-card:hover .thumb {
        transform: translateY(-1px) scale(1.01);
        box-shadow:
          0 20px 34px -24px rgba(0, 0, 0, .58),
          0 5px 10px -7px rgba(0, 0, 0, .46);
        filter: saturate(1.06) contrast(1.05);
      }
      .news-card h3 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.35em;
      }
      .skeleton-card { pointer-events: none; }
      .skel {
        position: relative;
        overflow: hidden;
        background: linear-gradient(90deg, var(--skel-a) 0%, var(--skel-b) 50%, var(--skel-a) 100%);
        background-size: 200% 100%;
        animation: shimmer 1.4s linear infinite;
      }
      .skel-thumb { width: 100%; aspect-ratio: 16 / 9; border-radius: 7px; border: 1px solid var(--line); }
      .skel-line { height: 10px; border-radius: 999px; }
      .skel-line.lg { height: 12px; width: 86%; }
      .skel-line.md { width: 70%; }
      .skel-line.sm { width: 56%; }
      .skel-stack { display: grid; gap: 7px; }
      @keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }
      .list { display: grid; gap: 7px; }
      .item { border: 1px solid var(--line); border-radius: 9px; padding: 7px; }
      .item p { margin: 0; font-size: .73rem; line-height: 1.3; }
      #copilot .box:last-of-type { overflow-y: auto; min-height: 0; }
      #copilotNote { overflow-wrap: break-word; word-break: break-word; }
      .item-head { display: flex; justify-content: space-between; gap: 6px; font-size: .66rem; color: var(--muted); margin-bottom: 5px; }
      .pill { border: 1px solid var(--line); border-radius: 999px; font-size: .63rem; padding: 2px 7px; }
      .pill.high { color: #c63636; border-color: rgba(198,54,54,.35); }
      .pill.medium { color: var(--warn); border-color: rgba(181,116,0,.35); }
      .pill.low { color: var(--success); border-color: rgba(15,138,78,.35); }
      .chat { display: grid; gap: 7px; }
      .bubble { border: 1px solid var(--line); border-radius: 9px; padding: 7px; font-size: .74rem; line-height: 1.3; }
      .bubble.user { background: rgba(115, 115, 115, 0.18); }
      .compose { display: grid; grid-template-columns: 1fr auto; gap: 7px; }
      .control, .select { height: 34px; padding: 0 9px; background: transparent; color: var(--text); font-size: .74rem; }
      .sliders { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 7px; }
      .sl { border: 1px solid var(--line); border-radius: 9px; padding: 7px; display: grid; gap: 4px; }
      .sl label { font-size: .68rem; color: var(--muted); }
      input[type='range'] { width: 100%; accent-color: var(--accent); }
      .settings-overlay { position: fixed; inset: 0; display: grid; place-items: center; background: rgba(0,0,0,.5); z-index: 40; }
      .settings { width: min(840px, 95vw); height: min(380px, 85vh); border: 1px solid var(--line); border-radius: 16px; background: var(--surface); display: grid; grid-template-columns: 210px 1fr; overflow: hidden; }
      .s-left { border-right: 1px solid var(--line); padding: 48px 10px 10px; display: grid; gap: 7px; align-content: start; }
      .s-right { padding: 52px 16px 14px; display: grid; grid-template-rows: auto 1fr; gap: 9px; }
      .s-btn { border: 1px solid transparent; border-radius: 9px; padding: 9px; text-align: left; background: transparent; color: var(--muted); }
      .s-btn.active { border-color: var(--line); color: var(--text); }
      .close { position: absolute; margin: 10px; width: 28px; height: 28px; border: 1px solid var(--line); border-radius: 8px; background: transparent; color: var(--text); cursor: pointer; }
      .theme-row { border-top: 1px solid var(--line); padding-top: 12px; display: flex; justify-content: space-between; align-items: center; }
      .theme-toggle { display: flex; gap: 4px; border: 1px solid var(--line); border-radius: 999px; padding: 3px; }
      .theme { min-width: 50px; height: 34px; border: 0; border-radius: 999px; background: transparent; color: var(--muted); cursor: pointer; font-size: .73rem; }
      .theme.active { background: var(--accent); color: #fff; }
      .company-text {
        width: 100%;
        height: 100%;
        min-height: 0;
        resize: none;
        border: 1px solid var(--line);
        border-radius: 9px;
        background: transparent;
        color: var(--text);
        padding: 10px;
        font-size: .73rem;
        line-height: 1.4;
        overflow: auto;
        white-space: pre-wrap;
      }
      @media (max-width: 1450px) {
        .news-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
      }
      @media (max-width: 1100px) {
        .kpis { grid-template-columns: repeat(2,minmax(0,1fr)); }
        .grid2 { grid-template-columns: 1fr; }
        .news-grid { grid-template-columns: 1fr; }
      }
      @media (max-width: 640px) {
        .kpis { grid-template-columns: 1fr; }
      }
      @media (max-width: 860px) {
        .tabs { overflow-x: auto; }
        .top { grid-template-columns: 1fr auto; grid-template-areas: 'b i' 'c c'; }
        .brand { grid-area: b; }
        .chips { grid-area: c; justify-content: flex-start; }
        #openSettings { grid-area: i; }
      }
    </style>
  </head>
  <body>
    <div class="app">
      <header class="card top">
        <section class="brand">
          <h1>Resolv DRS Studio</h1>
          <p>Autonomous supply chain resilience command system.</p>
        </section>
        <section class="chips">
          <span class="chip"><span id="newsDot" class="dot"></span><span id="newsMode">News: Demo</span></span>
          <span class="chip"><span id="gemDot" class="dot"></span><span id="gemMode">Gemini: Fallback</span></span>
          <span class="chip"><span class="dot live"></span><span id="cycle">Cycle: --</span></span>
        </section>
        <button id="openSettings" class="icon" type="button" aria-label="Open settings">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M11 2h2l.4 1.8c.5.1 1 .3 1.4.6l1.6-.9 1.4 1.4-.9 1.6c.2.5.4 1 .6 1.4L20 9v2l-1.8.4c-.1.5-.3 1-.6 1.4l.9 1.6-1.4 1.4-1.6-.9c-.4.2-.9.4-1.4.6L13 20h-2l-.4-1.8c-.5-.1-1-.3-1.4-.6l-1.6.9-1.4-1.4.9-1.6c-.2-.4-.4-.9-.6-1.4L4 11V9l1.8-.4c.1-.5.3-1 .6-1.4l-.9-1.6 1.4-1.4 1.6.9c.4-.2.9-.4 1.4-.6L11 2Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
            <circle cx="12" cy="10" r="3.2" stroke="currentColor" stroke-width="1.2"></circle>
          </svg>
        </button>
      </header>

      <nav class="card tabs">
        <button class="nav-btn active" type="button" data-panel="dashboard">Dashboard</button>
        <button class="nav-btn" type="button" data-panel="intelligence">Intelligence</button>
        <button class="nav-btn" type="button" data-panel="copilot">Copilot</button>
        <button class="nav-btn" type="button" data-panel="actions">Actions</button>
        <button class="nav-btn" type="button" data-panel="controls">Controls</button>
        <button class="nav-btn" type="button" data-panel="company">Your Company</button>
      </nav>

      <main class="card workspace">
        <section id="dashboard" class="panel dashboard active" aria-hidden="false">
          <div class="kpis">
            <article class="kpi">
              <header class="kpi-head">
                <h2>Disruption Probability</h2>
              </header>
              <div class="kpi-body risk-body">
                <div id="riskPie" class="risk-pie" role="img" aria-label="Disruption probability out of 100">
                  <strong id="kRisk" class="metric metric-in-chart">0 / 100</strong>
                </div>
                <div class="kpi-copy">
                  <span id="riskBand" class="small">Risk band --</span>
                  <span class="small subtle">Signal-weighted probability for the next 72h window.</span>
                </div>
              </div>
            </article>
            <article class="kpi">
              <header class="kpi-head">
