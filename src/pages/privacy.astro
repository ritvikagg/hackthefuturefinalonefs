---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle: string = `Privacy | ${SITE.title}`;
---

<MainLayout title={pageTitle}>
  <section class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
    <div class="rounded-4xl border border-[var(--resolv-border)] bg-[var(--resolv-surface)] p-8 md:p-12">
      <p class="text-sm font-semibold tracking-[0.18em] text-[var(--resolv-muted)]">PRIVACY</p>
      <h1 class="mt-4 text-5xl md:text-6xl">Privacy Policy</h1>
      <div class="mt-6 grid gap-6 text-[var(--resolv-muted)]">
        <p>
          Resolv DRS only uses operational and user-provided data to power risk detection,
          simulations, and mitigation recommendations.
        </p>
        <p>
          We do not sell personal data. Access to workflow history and risk signals is restricted
          to authorized users and audited for governance.
        </p>
        <p>
          Questions about privacy can be sent through the <a class="underline" href="/contact">contact page</a>.
        </p>
      </div>
    </div>
  </section>
</MainLayout>
