---
import { Image } from 'astro:assets';
import Icon from '../../ui/icons/Icon.astro';

const { content, author, role, avatarSrc } = Astro.props;

interface Props {
  content: string;
  author: string;
  role: string;
  avatarSrc: string;
}
---

<blockquote class="relative rounded-3xl border border-[var(--resolv-border)] bg-[var(--resolv-surface)] p-6">
  <Icon name="quotation" />

  <div class="relative z-10">
    <p class="text-xl text-[var(--resolv-text)] italic">
      {content}
    </p>
  </div>

  <div class="mt-6">
    <div class="flex items-center">
      <div class="shrink-0">
        <Image
          class="ui-avatar h-8 w-8 rounded-full"
          src={avatarSrc}
          alt="Avatar Description"
          loading={'eager'}
          inferSize
        />
      </div>
      <div class="ms-4 grow">
        <div class="font-semibold text-[var(--resolv-text)]">
          {author}
        </div>
        <div class="text-xs text-[var(--resolv-muted)]">{role}</div>
      </div>
    </div>
  </div>
</blockquote>
