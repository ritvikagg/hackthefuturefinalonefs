---
// Define props from Astro
const { title, subTitle, partners } = Astro.props;

interface Partner {
  icon: any;
  name?: string;
  href?: string;
}

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  partners: Partner[];
}
---

<section
  class="mx-auto max-w-[85rem] rounded-4xl border border-[var(--resolv-border)] bg-[var(--resolv-surface)] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  {/* Title and description */}
  <div class="mx-auto mb-6 w-full max-w-4xl space-y-1 text-center sm:w-5/6 lg:w-3/4">
    <h2
      class="text-3xl leading-tight text-balance text-[var(--resolv-text)] sm:text-4xl"
    >
      {title}
    </h2>
    {
      subTitle && (
      <p class="mx-auto max-w-3xl leading-tight text-pretty text-[var(--resolv-muted)]">
          {subTitle}
        </p>
      )
    }
  </div>
  <div
    class="flex flex-col items-center justify-center gap-y-2 sm:flex-row sm:gap-x-12 sm:gap-y-0 lg:gap-x-24"
  >
    {/* Clients Group SVGs */}
    {
      partners.map(partner => (
        partner.href ? (
          <a href={partner.href} target="_blank" rel="noopener noreferrer">
            <div set:html={partner.icon} />
          </a>
        ) : (
          <div set:html={partner.icon} />
        )
      ))
    }
  </div>
</section>
