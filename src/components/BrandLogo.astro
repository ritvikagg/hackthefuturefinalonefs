---
const { class: className = '' } = Astro.props;
const uid = `resolv-${Math.random().toString(36).slice(2, 10)}`;
const ombreId = `${uid}-ombre`;
const highlightId = `${uid}-highlight`;
---

<div class={`inline-flex min-w-max items-center gap-3 font-bold tracking-tight text-[var(--resolv-text)] dark:text-[var(--resolv-text)] ${className}`}>
  <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[var(--resolv-border)] shadow-[0_6px_18px_-14px_rgba(16,45,30,0.7)] overflow-hidden">
    <svg viewBox="0 0 64 64" class="h-full w-full" aria-hidden="true" focusable="false">
      <defs>
        <linearGradient id={ombreId} x1="10" y1="8" x2="54" y2="56" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#B8F3D2" />
          <stop offset="45%" stop-color="#5CCB92" />
          <stop offset="100%" stop-color="#1E6A43" />
        </linearGradient>

        <radialGradient id={highlightId} cx="24" cy="18" r="28" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.55" />
          <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0" />
        </radialGradient>
      </defs>

      {/* Ombre badge background */}
      <rect x="2" y="2" width="60" height="60" rx="12" fill={`url(#${ombreId})`} />

      {/* Soft highlight */}
      <circle cx="22" cy="18" r="22" fill={`url(#${highlightId})`} />

      {/* Centered R */}
      <text
        x="32"
        y="40"
        text-anchor="middle"
        font-size="30"
        font-weight="800"
        font-family="ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial"
        fill="#FFFFFF"
        opacity="0.95"
      >
        R
      </text>

      {/* Subtle inner stroke for crispness */}
      <rect x="3.5" y="3.5" width="57" height="57" rx="10.5" fill="none" stroke="#0B2A1A" stroke-opacity="0.18" />
    </svg>
  </span>

  <span class="inline-block h-8 w-px bg-[var(--resolv-border)]"></span>
  <span class="text-3xl font-semibold leading-none">Resolv</span>
</div>
